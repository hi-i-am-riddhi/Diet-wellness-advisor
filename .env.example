# ─────────────────────────────────────────────────────────────────────────────
#  IBM watsonx Orchestrate – Diet & Wellness Advisor
#  Copy this file to .env and fill in your real credentials.
#  NEVER commit .env to source control.
#  Save this file as UTF-8 WITHOUT BOM (in VS Code: bottom-right encoding menu).
# ─────────────────────────────────────────────────────────────────────────────

# Orchestrate instance URL — includes /instances/<id>, no trailing slash.
# Format: https://api.<region>.watson-orchestrate.cloud.ibm.com/instances/<instance-id>
# Find it: IBM Cloud → Resource list → your Orchestrate instance → Service credentials
ORCHESTRATE_INSTANCE_URL=https://api.eu-de.watson-orchestrate.cloud.ibm.com/instances/YOUR_INSTANCE_ID

# IBM Cloud IAM API Key  (cloud.ibm.com/iam/apikeys → Create)
# Paste the key exactly — no quotes, no leading/trailing spaces.
ORCHESTRATE_API_KEY=your_ibm_cloud_api_key_here

# The Agent ID shown in Orchestrate → your agent → Settings → API details
ORCHESTRATE_AGENT_ID=your_agent_id_here

# Which agent environment to chat with:
#   "live"  — the published / production agent  (default, recommended)
#   "draft" — the unpublished working copy
# You can also paste a custom environment UUID here.
ORCHESTRATE_ENVIRONMENT_ID=live

# Flask secret key — use a long random string in production
FLASK_SECRET_KEY=change_me_to_a_long_random_string

# Flask environment  (development | production)
FLASK_ENV=development

# Port for the Flask dev server
PORT=5000
